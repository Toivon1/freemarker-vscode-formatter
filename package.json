{
    "name": "ftl-formatter",
    "displayName": "FTL Formatter",
    "description": "Config-driven FreeMarker formatter and syntax highlighter. Edit ftl.config.json at the repo root to change indentation and colors.",
    "version": "1.0.2",
    "publisher": "Toikr",
    "license": "MIT",
    "repository": {
        "type": "git",
        "url": "https://github.com/Toivon1/freemarker-vscode-formatter"
    },
    "engines": {
        "vscode": "^1.74.0"
    },
    "categories": [
        "Formatters",
        "Programming Languages"
    ],
    "activationEvents": [
        "onLanguage:ftl"
    ],
    "main": "./extension.js",
    "contributes": {
        "languages": [
            {
                "id": "ftl",
                "aliases": [
                    "FreeMarker",
                    "FTL"
                ],
                "extensions": [
                    ".ftl"
                ]
            }
        ],
        "grammars": [
            {
                "language": "ftl",
                "scopeName": "text.html.ftl",
                "path": "./syntaxes/ftl.tmLanguage.json"
            }
        ]
    }
}
